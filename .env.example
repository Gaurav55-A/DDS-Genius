# ==================================
# DDR Genius - Environment Variables
# ==================================
# Copy this file to .env and fill in your actual values
# For Vercel: Add these in Project Settings → Environment Variables

# ----------------------------------
# Supabase Configuration (REQUIRED)
# ----------------------------------
# Get these from: https://supabase.com/dashboard → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ----------------------------------
# AI / LLM Configuration (REQUIRED)
# ----------------------------------
# Anthropic Claude API Key for AI-powered data matching
# Use Emergent Universal Key or your own Anthropic API key
ANTHROPIC_API_KEY=sk-emergent-your-key-here
EMERGENT_LLM_KEY=sk-emergent-your-key-here

# ----------------------------------
# Application Configuration
# ----------------------------------
# Base URL for your application (auto-set by Vercel, but can override)
NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app

# CORS allowed origins (use * for development, specific domains for production)
CORS_ORIGINS=*

# ----------------------------------
# Database Configuration (Optional)
# ----------------------------------
# MongoDB connection (if using MongoDB for local development)
# Not required if only using Supabase
MONGO_URL=mongodb://localhost:27017
DB_NAME=ddr_genius

# ----------------------------------
# Notes for Vercel Deployment
# ----------------------------------
# 1. Go to: https://vercel.com/dashboard
# 2. Select your project
# 3. Go to Settings → Environment Variables
# 4. Add each variable above (except the optional MongoDB ones)
# 5. Set them for: Production, Preview, and Development
# 6. Redeploy your application

# ----------------------------------
# Security Notes
# ----------------------------------
# ⚠️ NEVER commit your actual .env file to Git
# ⚠️ Keep your API keys secret
# ⚠️ Use different keys for development and production
# ⚠️ Rotate keys if they're ever exposed

